# ChatISP AI Backend - Environment Configuration

# Application
APP_NAME="ChatISP AI"
CREATOR="MBILIZI"
DEBUG=false

# Groq LLM
GROQ_API_KEY="your_groq_api_key_here"
MODEL_NAME="mixtral-8x7b-32768"           # Choose a Groq model
TEMPERATURE=0.7
MAX_TOKENS=4096

# Rate Limiting & Quotas (Groq)
GROQ_RATE_LIMIT_MAX_CALLS=30
GROQ_RATE_LIMIT_PERIOD=60
GROQ_RATE_LIMIT_MAX_WAIT=10
GROQ_DAILY_TOKEN_QUOTA=1000000

# RAG & Embeddings
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
CHROMA_PATH="./data/vector_store"
SIMILARITY_THRESHOLD=0.75

# Memory
MEMORY_LIMIT=10

# Database (PostgreSQL recommandé en production)
# Pour PostgreSQL, utiliser le format: postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL="postgresql+asyncpg://chatisp_user:change_me@localhost:5432/chatisp_db"

# Variables détaillées pour PostgreSQL (optionnel, utilisé par docker-compose)
POSTGRES_USER=chatisp_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chatisp_db

# Logging
LOG_LEVEL="INFO"
LOG_FILE="./data/logs/app.json"

# CORS (comma‑separated origins, use "*" for development)
CORS_ORIGINS="*"

# JWT Security
JWT_SECRET_KEY="change_this_in_production_use_env_variable"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_DAYS=30
REFRESH_TOKEN_EXPIRE_DAYS=180

# Google OAuth2 (remplacer par votre client ID)
GOOGLE_CLIENT_ID=""