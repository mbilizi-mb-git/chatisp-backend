# Production environment variables for ChatISP AI

APP_NAME="ChatISP AI"
CREATOR="MBILIZI"

# Groq LLM - MUST BE SET IN DEPLOYMENT (e.g., via secrets)
GROQ_API_KEY=""
MODEL_NAME="mixtral-8x7b-32768"
TEMPERATURE=0.7
MAX_TOKENS=4096

# Rate Limiting & Quotas
GROQ_RATE_LIMIT_MAX_CALLS=30
GROQ_RATE_LIMIT_PERIOD=60
GROQ_RATE_LIMIT_MAX_WAIT=10
GROQ_DAILY_TOKEN_QUOTA=1000000

# RAG & Embeddings
EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"
CHROMA_PATH="./data/vector_store"
SIMILARITY_THRESHOLD=0.75

# Memory
MEMORY_LIMIT=10

# Database (SQLite path; for production consider a volume)
DATABASE_URL="sqlite+aiosqlite:///./data/chatisp.db"

# Logging
LOG_LEVEL="INFO"
LOG_FILE="./data/logs/app.json"

# CORS (comma-separated origins, use specific domains in production)
CORS_ORIGINS="https://your-frontend-domain.com"